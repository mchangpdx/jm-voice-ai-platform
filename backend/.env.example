# ── Supabase (required / 필수) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Gemini AI (required / 필수) ────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Solink CCTV Relay (optional — leave blank to disable / 선택사항) ────────
SOLINK_API_URL=
SOLINK_API_KEY=

# ── Loyverse POS Relay (optional — leave blank to disable / 선택사항) ───────
LOYVERSE_API_URL=https://api.loyverse.com/v1.0
LOYVERSE_API_KEY=

# ── Relay settings (optional / 선택사항) ─────────────────────────────────────
RELAY_TIMEOUT_SECONDS=8

# ── Debug (optional / 선택사항) ───────────────────────────────────────────────
DEBUG=false
